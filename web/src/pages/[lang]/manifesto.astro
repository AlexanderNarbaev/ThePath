---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t } from '../../i18n/ui';
import { getLangPaths } from '../../utils/static-paths';
import { BASE_PATH } from '../../constants';

export async function getStaticPaths() {
  return getLangPaths();
}

const { lang } = Astro.params;
const allPages = await getCollection('pages');
const page = allPages.find((e) => e.id.includes('manifesto') && e.data?.lang === lang);
if (!page) return Astro.redirect(`${BASE_PATH}/${lang}`);
const { Content } = await page.render();
---

<BaseLayout lang={lang as 'ru' | 'en'} title={t('manifesto.title' as any, lang as 'ru' | 'en')}>
  <div class="content-wide">
    <article class="manifesto">
      <Content />
    </article>
  </div>
</BaseLayout>

<style>
  .manifesto { border: 2px solid var(--color-gold); border-radius: 12px; padding: 3rem 2rem; margin: 2rem 0; }
  .manifesto :global(h1) { font-size: 2.5rem; }
  .manifesto :global(h2) { margin-top: 2rem; padding-top: 1.5rem; border-top: 1px solid var(--color-border); }
  @media (max-width: 768px) { .manifesto { padding: 1.5rem 1rem; } }
</style>
