---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import { t, type Lang } from '../../i18n/ui';
import { getLangPaths } from '../../utils/static-paths';
import { BASE_PATH } from '../../constants';

export async function getStaticPaths() {
  return getLangPaths();
}

const lang = Astro.params.lang as Lang;
const allPages = await getCollection('pages');
const page = allPages.find((e) => e.id.includes('manifesto') && e.data?.lang === lang);
if (!page) return Astro.redirect(`${BASE_PATH}/${lang}`);
const { Content } = await page.render();
---

<BaseLayout lang={lang} title={t('manifesto.title', lang)}>
  <div class="content-wide">
    <article class="manifesto">
      <div class="manifesto-header">
        <div class="meta-label">{t('manifesto.section_label', lang)}</div>
      </div>
      <Content />
    </article>
    <div class="manifesto-cta">
      <h2>{t('manifesto.next_title', lang)}</h2>
      <div class="manifesto-cta-links">
        <a href={`/ThePath/${lang}/paths/quickstart`} class="btn-primary">{t('paths.quick_title', lang)}</a>
        <a href={`/ThePath/${lang}/map`} class="btn-secondary">{t('map.view_all', lang)}</a>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .manifesto-header { text-align: center; margin-bottom: 2rem; }
  .manifesto {
    border: 2px solid var(--color-gold);
    border-radius: 12px;
    padding: 3rem 2rem;
    margin: 2rem 0;
    background: var(--color-card-bg);
    box-shadow: 0 0 40px rgba(230, 193, 123, 0.05);
  }
  .manifesto :global(h1) {
    font-size: 2.5rem;
    font-weight: 300;
    letter-spacing: -0.02em;
    text-align: center;
    margin-bottom: 2rem;
  }
  .manifesto :global(h2) {
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--color-border);
    font-weight: 300;
    color: var(--color-gold);
  }
  .manifesto :global(h3) {
    color: var(--color-cosmic-text);
    font-weight: 500;
    margin-top: 1.5rem;
  }
  .manifesto :global(blockquote) {
    border-left: 3px solid var(--color-gold);
    background: var(--color-bg-secondary);
    border-radius: 0 8px 8px 0;
    padding: 1rem 1.25rem;
    margin: 1.5rem 0;
  }
  .manifesto :global(strong) {
    color: var(--color-cosmic-text);
  }
  .manifesto-cta {
    text-align: center;
    margin: 3rem 0 2rem;
    padding: 2rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-card-bg);
  }
  .manifesto-cta h2 {
    font-size: 1.5rem;
    font-weight: 300;
    color: var(--color-gold);
    margin-bottom: 1.25rem;
  }
  .manifesto-cta-links {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }
  @media (max-width: 768px) {
    .manifesto { padding: 1.5rem 1rem; }
    .manifesto :global(h1) { font-size: 1.75rem; }
    .manifesto-cta { padding: 1.5rem 1rem; }
  }
</style>
