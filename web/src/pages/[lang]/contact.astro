---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/forms/ContactForm';
import { t, type Lang } from '../../i18n/ui';
import { getLangPaths } from '../../utils/static-paths';

export async function getStaticPaths() {
  return getLangPaths();
}

const lang = Astro.params.lang as Lang;
const web3Key = import.meta.env.PUBLIC_WEB3FORMS_KEY || '';
---

<BaseLayout lang={lang} title={t('contact.title', lang)}>
  <div class="contact-page">
    <div class="contact-intro">
      <h1>{t('contact.title', lang)}</h1>
      <p>{t('contact.intro', lang)}</p>
    </div>
    <div class="contact-card">
      <ContactForm lang={lang} web3Key={web3Key} client:visible />
    </div>
  </div>
</BaseLayout>

<style>
  .contact-page {
    max-width: 760px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }
  .contact-intro {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .contact-intro h1 { font-size: 2rem; font-weight: 300; }
  .contact-intro p {
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.6;
    max-width: 480px;
    margin: 0.75rem auto 0;
  }
  .contact-card {
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 2.5rem;
  }
  @media (max-width: 768px) {
    .contact-page { padding: 2rem 1rem 3rem; }
    .contact-card { padding: 1.25rem; border-radius: 12px; }
  }

  /* Form */
  .cf-form { display: flex; flex-direction: column; gap: 1.5rem; }
  .cf-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
  .cf-field { display: flex; flex-direction: column; gap: 0.4rem; }
  .cf-label {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .cf-box {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: var(--color-bg-secondary);
    transition: border-color 0.2s, box-shadow 0.2s;
    overflow: hidden;
  }
  .cf-box:focus-within {
    border-color: var(--color-gold);
    box-shadow: 0 0 0 3px rgba(230, 193, 123, 0.12);
  }
  .cf-box-err { border-color: var(--color-danger) !important; box-shadow: 0 0 0 3px rgba(231, 76, 60, 0.12) !important; }

  .cf-input {
    width: 100%;
    padding: 0.75rem 0.95rem;
    border: none;
    background: transparent;
    color: var(--color-text-primary);
    font-size: 0.95rem;
    font-family: inherit;
    outline: none;
    line-height: 1.5;
  }
  .cf-input::placeholder { color: var(--color-text-secondary); opacity: 0.6; }

  /* Editor */
  .cf-editor-box { min-height: 340px; display: flex; flex-direction: column; }
  .cf-toolbar {
    display: flex;
    gap: 0;
    padding: 0.35rem 0.5rem;
    border-bottom: 1px solid var(--color-border);
    background: rgba(0,0,0,0.12);
    align-items: center;
    flex-wrap: wrap;
  }
  .cf-icon { width: 16px; height: 16px; flex-shrink: 0; }
  .cf-sent-icon { width: 48px; height: 48px; color: var(--color-gold); margin-bottom: 1rem; }
  .cf-tb-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.35rem 0.6rem;
    border: 1px solid transparent;
    border-radius: 6px;
    background: transparent;
    color: var(--color-text-secondary);
    font-size: 0.82rem;
    cursor: pointer;
    transition: all 0.15s;
    line-height: 1;
    font-family: inherit;
    white-space: nowrap;
  }
  .cf-tb-btn:hover {
    background: var(--color-border);
    color: var(--color-text-primary);
  }
  .cf-tb-active, .cf-tb-active:hover {
    background: rgba(230, 193, 123, 0.15);
    color: var(--color-gold);
    border-color: rgba(230, 193, 123, 0.3);
  }
  .cf-tb-text { font-size: 0.73rem; }
  .cf-tb-sep {
    width: 1px;
    height: 22px;
    background: var(--color-border);
    margin: 0 0.4rem;
  }
  .cf-tb-spacer { flex: 1; }
  .cf-tb-clear { margin-left: auto; }
  .cf-editor {
    flex: 1;
    padding: 1.1rem 1.1rem;
    font-size: 0.95rem;
    line-height: 1.8;
    color: var(--color-text-primary);
    outline: none;
    min-height: 280px;
    word-break: break-word;
  }
  .cf-editor:empty::before {
    content: attr(data-placeholder);
    color: var(--color-text-secondary);
    opacity: 0.4;
    pointer-events: none;
  }
  .cf-editor pre {
    background: var(--color-cosmic-light);
    padding: 0.75rem 1rem;
    border-radius: 6px;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    line-height: 1.5;
    overflow-x: auto;
    margin: 0.5rem 0;
    white-space: pre-wrap;
    border: 1px solid var(--color-border);
  }
  .cf-editor blockquote {
    border-left: 3px solid var(--color-gold);
    padding: 0.25rem 0 0.25rem 1rem;
    margin: 0.5rem 0;
    font-style: italic;
    color: var(--color-text-secondary);
  }
  .cf-editor a { color: var(--color-gold); text-decoration: underline; }
  .cf-editor code {
    font-family: var(--font-mono);
    background: var(--color-cosmic-light);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.9em;
    border: 1px solid var(--color-border);
  }

  .cf-footer {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    margin-top: 0.25rem;
  }
  .cf-btn {
    padding: 0.85rem 3rem;
    background: var(--color-gold);
    color: #0a0a14;
    border: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
    font-family: var(--font-mono);
    letter-spacing: 0.03em;
  }
  .cf-btn:hover:not(:disabled) { opacity: 0.9; transform: translateY(-1px); }
  .cf-btn:disabled { opacity: 0.5; cursor: not-allowed; transform: none; }
  .cf-val-err { color: var(--color-danger); font-size: 0.78rem; margin-top: 0.2rem; }
  .cf-error-block { text-align: center; width: 100%; }
  .cf-error { color: var(--color-danger); font-size: 0.85rem; margin: 0; }
  .cf-error-hint { color: var(--color-text-secondary); font-size: 0.82rem; margin: 0.3rem 0 0; }
  .cf-error-hint a { color: var(--color-gold); }

  .cf-success {
    text-align: center;
    padding: 2.5rem 1rem;
  }
  .cf-success h2 {
    color: var(--color-cosmic-text);
    font-size: 1.3rem;
    margin: 0 0 0.5rem;
  }
  .cf-success p {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  @media (max-width: 480px) {
    .cf-row { grid-template-columns: 1fr; }
  }
</style>
