---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/forms/ContactForm';
import { t, type Lang } from '../../i18n/ui';
import { getLangPaths } from '../../utils/static-paths';

export async function getStaticPaths() {
  return getLangPaths();
}

const lang = Astro.params.lang as Lang;
const web3Key = import.meta.env.PUBLIC_WEB3FORMS_KEY || '';
---

<BaseLayout lang={lang} title={t('contact.title', lang)}>
  <div class="contact-page">
    <div class="contact-intro">
      <h1>{t('contact.title', lang)}</h1>
      <p>{t('contact.intro', lang)}</p>
    </div>
    <div class="contact-card">
      <ContactForm lang={lang} web3Key={web3Key} client:visible />
    </div>
  </div>
</BaseLayout>

<style>
  .contact-page {
    max-width: 640px;
    margin: 0 auto;
    padding: 3rem 1.5rem 5rem;
  }
  .contact-intro {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .contact-intro h1 {
    font-size: 2rem;
    font-weight: 300;
  }
  .contact-intro p {
    color: var(--color-text-secondary);
    font-size: 1rem;
    line-height: 1.6;
    max-width: 420px;
    margin: 0.75rem auto 0;
  }
  .contact-card {
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 16px;
    padding: 2rem;
  }
  @media (max-width: 768px) {
    .contact-page { padding: 2rem 1rem 3rem; }
    .contact-card { padding: 1.25rem; border-radius: 12px; }
  }

  /* Form elements — scoped to contact page */
  .cf-form { display: flex; flex-direction: column; gap: 1rem; }
  .cf-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .cf-field { display: flex; flex-direction: column; gap: 0.3rem; }
  .cf-label { font-size: 0.8rem; font-weight: 600; color: var(--color-text-secondary); letter-spacing: 0.02em; }
  .cf-input {
    padding: 0.7rem 0.9rem;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    background: var(--color-bg-secondary);
    color: var(--color-text-primary);
    font-size: 0.95rem;
    font-family: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .cf-input::placeholder { color: var(--color-text-secondary); opacity: 0.5; }
  .cf-input:focus { outline: none; border-color: var(--color-gold); box-shadow: 0 0 0 3px rgba(230, 193, 123, 0.15); }
  .cf-textarea { resize: vertical; min-height: 120px; line-height: 1.6; }
  .cf-footer { display: flex; align-items: center; gap: 1rem; margin-top: 0.5rem; }
  .cf-btn {
    padding: 0.75rem 2rem;
    background: var(--color-gold);
    color: #0a0a14;
    border: none;
    border-radius: 10px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
    font-family: var(--font-mono);
  }
  .cf-btn:hover:not(:disabled) { opacity: 0.9; transform: translateY(-1px); }
  .cf-btn:disabled { opacity: 0.5; cursor: not-allowed; }
  .cf-error { color: var(--color-danger); font-size: 0.85rem; margin: 0; }
  .cf-success {
    text-align: center;
    padding: 2rem 1rem;
  }
  .cf-success-icon {
    font-size: 2.5rem;
    color: #27ae60;
    margin-bottom: 1rem;
  }
  .cf-success h2 {
    color: var(--color-cosmic-text);
    font-size: 1.3rem;
    margin: 0 0 0.5rem;
  }
  .cf-success p {
    color: var(--color-text-secondary);
    font-size: 0.95rem;
    line-height: 1.5;
  }

  @media (max-width: 480px) {
    .cf-row { grid-template-columns: 1fr; }
  }
</style>
