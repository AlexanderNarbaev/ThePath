---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/forms/ContactForm';
import { t, type Lang } from '../../i18n/ui';
import { getLangPaths } from '../../utils/static-paths';

export async function getStaticPaths() { return getLangPaths(); }
const lang = Astro.params.lang as Lang;
const web3Key = import.meta.env.PUBLIC_WEB3FORMS_KEY || '';
---

<BaseLayout lang={lang} title={t('contact.title', lang)}>
  <div class="contact-page">
    <div class="contact-head">
      <h1>{t('contact.title', lang)}</h1>
      <p>{t('contact.intro', lang)}</p>
    </div>
    <ContactForm lang={lang} web3Key={web3Key} client:visible />
  </div>
</BaseLayout>

<style>
  .contact-page {
    max-width: 560px;
    margin: 0 auto;
    padding: 4rem 1.5rem 5rem;
  }
  .contact-head {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .contact-head h1 {
    font-size: 1.65rem;
    font-weight: 300;
    color: var(--color-text-primary);
    margin: 0 0 0.5rem;
  }
  .contact-head p {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
    max-width: 360px;
    margin: 0 auto;
  }

  /* Form */
  .cf-form { display: flex; flex-direction: column; gap: 1.25rem; }
  .cf-grp { display: flex; flex-direction: column; gap: 0.35rem; }
  .cf-lbl {
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-secondary);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
  .cf-inp {
    padding: 0.7rem 0.9rem;
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.035);
    color: var(--color-text-primary);
    font-size: 0.95rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    line-height: 1.5;
    resize: vertical;
  }
  .cf-inp:focus {
    border-color: var(--color-gold);
    box-shadow: 0 0 0 3px rgba(230, 193, 123, 0.1);
  }
  .cf-inp::placeholder {
    color: var(--color-text-secondary);
    opacity: 0.35;
  }
  textarea.cf-inp { min-height: 180px; line-height: 1.65; }

  .cf-btn {
    align-self: flex-start;
    padding: 0.75rem 2rem;
    background: var(--color-gold);
    color: #0a0a14;
    border: none;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.9rem;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s, box-shadow 0.15s;
    font-family: var(--font-mono);
    letter-spacing: 0.03em;
    margin-top: 0.25rem;
  }
  .cf-btn:hover:not(:disabled) {
    opacity: 0.92;
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(230, 193, 123, 0.18);
  }
  .cf-btn:disabled { opacity: 0.4; cursor: not-allowed; transform: none; box-shadow: none; }

  .cf-err {
    font-size: 0.82rem;
    color: var(--color-text-secondary);
    margin: 0;
    line-height: 1.5;
  }
  .cf-err a { color: var(--color-gold); }

  .cf-done {
    text-align: center;
    padding: 2rem 1.5rem;
  }
  .cf-done-mark {
    width: 52px; height: 52px;
    margin: 0 auto 1.25rem;
    border-radius: 50%;
    background: rgba(39, 174, 96, 0.1);
    border: 2px solid rgba(39, 174, 96, 0.25);
    color: #27ae60;
    font-size: 1.4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
  }
  .cf-done h2 {
    color: var(--color-text-primary);
    font-size: 1.2rem;
    font-weight: 400;
    margin: 0 0 0.5rem;
  }
  .cf-done p {
    color: var(--color-text-secondary);
    font-size: 0.9rem;
    line-height: 1.6;
  }

  @media (max-width: 480px) {
    .contact-page { padding: 2rem 1rem 3rem; }
  }
</style>
