---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ModuleGraph from '../../components/map/ModuleGraph';
import PathTracker from '../../components/interactive/PathTracker';
import { t, type Lang } from '../../i18n/ui';
import { modules } from '../../i18n/modules';
import { paths } from '../../i18n/paths';
import { getLangPaths } from '../../utils/static-paths';
import { BASE_PATH } from '../../constants';

export async function getStaticPaths() {
  return getLangPaths();
}

const lang = Astro.params.lang as Lang;
const allPages = await getCollection('pages');
const page = allPages.find((e) => e.id.includes('map') && e.data?.lang === lang);
if (!page) return Astro.redirect(`${BASE_PATH}/${lang}`);
const { Content } = await page.render();
const base = BASE_PATH;

const moduleCards = modules.map((m) => ({
  icon: `M${m.number}`,
  title: lang === 'ru' ? m.title.ru : m.title.en,
  description: lang === 'ru' ? m.subtitle.ru : m.subtitle.en,
  href: `${base}/${lang}/modules/${m.slug}`,
}));
---

<BaseLayout lang={lang} title={t('map.title', lang)}>
  <div class="content-wide">
    <h1>{t('map.title', lang)}</h1>
    <PathTracker lang={lang} client:visible />
    <Content />

    <section class="map-section">
      <h2>{t('map.modules', lang)}</h2>
      <ModuleGraph lang={lang} client:visible />
    </section>

    <section class="map-section">
      <h2>{t('map.modules_list', lang)}</h2>
      <div class="module-grid">
        {moduleCards.map((card) => (
          <a href={card.href} class="module-card">
            <div class="module-card-icon">{card.icon}</div>
            <h3>{card.title}</h3>
            <p>{card.description}</p>
          </a>
        ))}
      </div>
    </section>

    <section class="map-section map-section-paths">
      <h2>{t('map.paths', lang)}</h2>
      {paths.map((p) => {
        const requiredModules = p.modules.map((n) => modules.find((m) => m.number === n)).filter(Boolean);
        const optionalMods = (p.optional || []).map((n) => modules.find((m) => m.number === n)).filter(Boolean);
        const recomMods = (p.recommended || []).map((n) => modules.find((m) => m.number === n)).filter(Boolean);
        return (
          <div class="path-detail">
            <h3>{lang === 'ru' ? p.name.ru : p.name.en}</h3>
            <p class="path-meta">{lang === 'ru' ? p.time.ru : p.time.en} &middot; {lang === 'ru' ? p.audience.ru : p.audience.en}</p>
            <p>{lang === 'ru' ? p.description.ru : p.description.en}</p>
            <div class="path-modules"><span class="label">{t('paths.required', lang)}:</span>
              {requiredModules.map((m) => m ? <a href={`${base}/${lang}/modules/${m.slug}`} class="module-chip">{lang === 'ru' ? m.title.ru : m.title.en}</a> : null)}
            </div>
            {p.optional && optionalMods.length > 0 && (<div class="path-modules"><span class="label">{t('paths.optional', lang)}:</span>
              {optionalMods.map((m) => m ? <a href={`${base}/${lang}/modules/${m.slug}`} class="module-chip chip-opt">{lang === 'ru' ? m.title.ru : m.title.en}</a> : null)}
            </div>)}
            {p.recommended && recomMods.length > 0 && (<div class="path-modules"><span class="label">{t('paths.recommended', lang)}:</span>
              {recomMods.map((m) => m ? <a href={`${base}/${lang}/modules/${m.slug}`} class="module-chip chip-rec">{lang === 'ru' ? m.title.ru : m.title.en}</a> : null)}
            </div>)}
            <a href={`${base}/${lang}/paths/${p.id}`} class="path-start-link">{t('paths.start', lang)} &rarr;</a>
          </div>
        );
      })}
    </section>
  </div>
</BaseLayout>

<style>
  .map-section { margin: 2rem 0; }
  .map-section-paths { margin: 3rem 0; }
  .module-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; }
  .module-card {
    display: block;
    background: var(--color-card-bg);
    border: 1px solid var(--color-border);
    border-radius: 12px;
    padding: 1.25rem;
    text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }
  .module-card:hover { border-color: var(--color-gold); transform: translateY(-2px); }
  .module-card-icon {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-gold);
    margin-bottom: 0.5rem;
    letter-spacing: 0.05em;
  }
  .module-card h3 { font-size: 1rem; margin: 0.25rem 0; font-weight: 500; color: var(--color-cosmic-text); }
  .module-card p { font-size: 0.82rem; color: var(--color-cosmic-text-secondary); line-height: 1.5; margin: 0; }
  .path-detail { background: var(--color-card-bg); border: 1px solid var(--color-border); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.25rem; }
  .path-detail h3 { margin-top: 0; }
  .path-meta { color: var(--color-text-secondary); font-size: 0.9rem; }
  .path-modules { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; margin: 0.5rem 0; }
  .label { font-size: 0.8rem; font-weight: 600; min-width: 7em; }
  .module-chip { font-size: 0.8rem; padding: 0.2rem 0.6rem; border-radius: 4px; background: var(--color-accent); color: white; text-decoration: none; display: inline-block; }
  .chip-opt { opacity: 0.5; }
  .chip-rec { background: var(--color-bg-secondary); color: var(--color-accent); border: 1px solid var(--color-accent); }
  .path-start-link { display: inline-block; margin-top: 0.75rem; font-weight: 600; color: var(--color-gold); }
</style>
