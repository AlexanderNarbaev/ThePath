---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ModuleGraph from '../../components/map/ModuleGraph';
import { t } from '../../i18n/ui';
import { modules } from '../../i18n/modules';
import { paths } from '../../i18n/paths';

export async function getStaticPaths() {
  return [{ params: { lang: 'ru' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;
const allPages = await getCollection('pages');
const page = allPages.find((e) => e.id.includes('map') && e.data?.lang === lang);
if (!page) return Astro.redirect(`/ThePath/${lang}`);
const { Content } = await page.render();
const base = '/ThePath';
---

<BaseLayout lang={lang as 'ru' | 'en'} title={t('map.title' as any, lang as 'ru' | 'en')}>
  <div class="content-wide">
    <h1>{t('map.title' as any, lang as 'ru' | 'en')}</h1>
    <Content />

    <section style="margin:2rem 0;">
      <h2>{t('map.modules' as any, lang as 'ru' | 'en')}</h2>
      <ModuleGraph lang={lang as 'ru' | 'en'} client:load />
    </section>

    <section style="margin:2rem 0;">
      <table>
        <thead><tr><th>#</th><th>{lang === 'ru' ? 'Название' : 'Title'}</th><th>{lang === 'ru' ? 'Аудитория' : 'Audience'}</th><th>{lang === 'ru' ? 'Путь' : 'Path'}</th></tr></thead>
        <tbody>
          {modules.map((m) => (
            <tr><td>{m.number}</td><td><a href={`${base}/${lang}/modules/${m.slug}`}>{lang === 'ru' ? m.title.ru : m.title.en}</a></td><td>{lang === 'ru' ? m.audience.ru : m.audience.en}</td><td><span class="path-badge">{m.path}</span></td></tr>
          ))}
        </tbody>
      </table>
    </section>

    <section style="margin:2rem 0;">
      <h2>{t('map.paths' as any, lang as 'ru' | 'en')}</h2>
      {paths.map((p) => {
        const requiredModules = p.modules.map((n) => modules.find((m) => m.number === n)).filter(Boolean);
        const optionalMods = (p.optional || []).map((n) => modules.find((m) => m.number === n)).filter(Boolean);
        const recomMods = (p.recommended || []).map((n) => modules.find((m) => m.number === n)).filter(Boolean);
        return (
          <div class="path-detail">
            <h3>{lang === 'ru' ? p.name.ru : p.name.en}</h3>
            <p class="path-meta">{lang === 'ru' ? p.time.ru : p.time.en} &middot; {lang === 'ru' ? p.audience.ru : p.audience.en}</p>
            <p>{lang === 'ru' ? p.description.ru : p.description.en}</p>
            <div class="path-modules"><span class="label">{t('paths.required' as any, lang as 'ru' | 'en')}:</span>
              {requiredModules.map((m) => m ? <a href={`${base}/${lang}/modules/${m.slug}`} class="module-chip">{lang === 'ru' ? m.title.ru : m.title.en}</a> : null)}
            </div>
            {p.optional && optionalMods.length > 0 && (<div class="path-modules"><span class="label">{t('paths.optional' as any, lang as 'ru' | 'en')}:</span>
              {optionalMods.map((m) => m ? <a href={`${base}/${lang}/modules/${m.slug}`} class="module-chip chip-opt">{lang === 'ru' ? m.title.ru : m.title.en}</a> : null)}
            </div>)}
            {p.recommended && recomMods.length > 0 && (<div class="path-modules"><span class="label">{t('paths.recommended' as any, lang as 'ru' | 'en')}:</span>
              {recomMods.map((m) => m ? <a href={`${base}/${lang}/modules/${m.slug}`} class="module-chip chip-rec">{lang === 'ru' ? m.title.ru : m.title.en}</a> : null)}
            </div>)}
            <a href={`${base}/${lang}/paths/${p.id}`} class="path-start-link">{t('paths.start' as any, lang as 'ru' | 'en')} &rarr;</a>
          </div>
        );
      })}
    </section>
  </div>
</BaseLayout>

<style>
  .path-badge { font-size: 0.75rem; padding: 0.15rem 0.5rem; border-radius: 4px; background: var(--color-bg-secondary); display: inline-block; }
  .path-detail { background: var(--color-card-bg); border: 1px solid var(--color-border); border-radius: 12px; padding: 1.5rem; margin-bottom: 1.25rem; }
  .path-detail h3 { margin-top: 0; }
  .path-meta { color: var(--color-text-secondary); font-size: 0.9rem; }
  .path-modules { display: flex; flex-wrap: wrap; gap: 0.5rem; align-items: center; margin: 0.5rem 0; }
  .label { font-size: 0.8rem; font-weight: 600; min-width: 7em; }
  .module-chip { font-size: 0.8rem; padding: 0.2rem 0.6rem; border-radius: 4px; background: var(--color-accent); color: white; text-decoration: none; display: inline-block; }
  .chip-opt { opacity: 0.5; }
  .chip-rec { background: var(--color-bg-secondary); color: var(--color-accent); border: 1px solid var(--color-accent); }
  .path-start-link { display: inline-block; margin-top: 0.75rem; font-weight: 600; color: var(--color-gold); }
</style>
