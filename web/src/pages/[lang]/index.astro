---
import { getCollection } from 'astro:content';
import HomeLayout from '../../layouts/HomeLayout.astro';
import Hero from '../../components/home/Hero.astro';
import ProhibitionsCards from '../../components/home/ProhibitionsCards.astro';
import PathCards from '../../components/home/PathCards.astro';
import DailyChecklist from '../../components/interactive/DailyChecklist';
import EthicalCompass from '../../components/interactive/EthicalCompass';
import { t } from '../../i18n/ui';

export async function getStaticPaths() {
  return [{ params: { lang: 'ru' } }, { params: { lang: 'en' } }];
}

const { lang } = Astro.params;
const allPages = await getCollection('pages');
const page = allPages.find((e) => e.id.includes('index') && e.data?.lang === lang);
const { Content } = page ? await page.render() : { Content: null };
---

<HomeLayout lang={lang as 'ru' | 'en'} title={t('site.name', lang as 'ru' | 'en')}>
  <Hero lang={lang as 'ru' | 'en'} />
  <div class="home-content">
    <ProhibitionsCards lang={lang as 'ru' | 'en'} />
    {Content && <div class="home-prose"><Content /></div>}
    <div class="home-interactive">
      <DailyChecklist lang={lang as 'ru' | 'en'} client:load />
      <EthicalCompass lang={lang as 'ru' | 'en'} client:load />
    </div>
    <PathCards lang={lang as 'ru' | 'en'} />
  </div>
</HomeLayout>

<style>
  .home-content { max-width: 960px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
  .home-prose { max-width: 720px; margin: 3rem auto 0; }
  .home-prose :global(h2) { font-size: 1.75rem; margin-top: 2rem; }
  .home-prose :global(table) { width: 100%; }
  .home-interactive { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1.5rem; margin: 2rem 0; }
</style>
