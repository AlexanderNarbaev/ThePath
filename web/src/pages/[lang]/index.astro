---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/home/Hero.astro';
import CardsGrid from '../../components/home/CardsGrid.astro';
import DailyChecklist from '../../components/interactive/DailyChecklist';
import { getLangPaths } from '../../utils/static-paths';
import { t, type Lang } from '../../i18n/ui';
import { modules } from '../../i18n/modules';

export async function getStaticPaths() {
  return getLangPaths();
}

const lang = Astro.params.lang as Lang;
---

<BaseLayout lang={lang} title={t('site.name', lang)}>

  <!-- §0: Hero -->
  <Hero lang={lang} />

  <!-- §1: Shared Beliefs -->
  <section class="longread-section" id="beliefs">
    <div class="meta-label">{t('beliefs.section_label', lang)}</div>
    <h2>{t('beliefs.heading', lang)}</h2>
    <div class="beliefs-grid">
      <a href={`/ThePath/${lang}/modules/3-practices`} class="belief-card">
        <h3>{t('beliefs.1_title', lang)}</h3>
        <p>{t('beliefs.1_desc', lang)}</p>
        <span class="belief-link">{t('beliefs.see_how', lang)}</span>
      </a>
      <a href={`/ThePath/${lang}/modules/2-ethics`} class="belief-card">
        <h3>{t('beliefs.2_title', lang)}</h3>
        <p>{t('beliefs.2_desc', lang)}</p>
        <span class="belief-link">{t('beliefs.see_how', lang)}</span>
      </a>
      <a href={`/ThePath/${lang}/modules/6-technology`} class="belief-card">
        <h3>{t('beliefs.3_title', lang)}</h3>
        <p>{t('beliefs.3_desc', lang)}</p>
        <span class="belief-link">{t('beliefs.see_how', lang)}</span>
      </a>
      <a href={`/ThePath/${lang}/modules/community-guide`} class="belief-card">
        <h3>{t('beliefs.4_title', lang)}</h3>
        <p>{t('beliefs.4_desc', lang)}</p>
        <span class="belief-link">{t('beliefs.see_how', lang)}</span>
      </a>
    </div>
  </section>

  <!-- §2: What This Is -->
  <section class="longread-section about-section" id="about">
    <div class="meta-label">{t('about.section_label', lang)}</div>
    <h2>{t('about.heading', lang)}</h2>
    <div class="about-grid">
      <div class="about-card">
        <h3>{t('about.tool', lang)}</h3>
        <p>{t('about.tool_desc', lang)}</p>
      </div>
      <div class="about-card">
        <h3>{t('about.open', lang)}</h3>
        <p>{t('about.open_desc', lang)}</p>
      </div>
      <div class="about-card">
        <h3>{t('about.community', lang)}</h3>
        <p>{t('about.community_desc', lang)}</p>
      </div>
    </div>
    <p class="section-cta">
      <a href="#practices">{t('how.cta', lang)}</a>
    </p>
  </section>

  <!-- §3: How It Works -->
  <section class="longread-section" id="practices">
    <div class="meta-label">{t('how.section_label', lang)}</div>
    <h2>{t('how.heading', lang)}</h2>

    <div class="practice-cards">
      <div class="practice-card">
        <div class="meta-label">☀️ {t('practices.morning', lang)}</div>
        <p>{t('practices.morning_text', lang)}</p>
        <span class="practice-time">{t('practices.time', lang)}</span>
      </div>
      <div class="practice-card">
        <div class="meta-label">📱 {t('practices.screen', lang)}</div>
        <p>{t('practices.screen_text', lang)}</p>
        <span class="practice-time">{t('practices.time', lang)}</span>
      </div>
      <div class="practice-card">
        <div class="meta-label">🌙 {t('practices.evening', lang)}</div>
        <p>{t('practices.evening_text', lang)}</p>
        <span class="practice-time">{t('practices.time', lang)}</span>
      </div>
    </div>

    <div class="practice-disclaimer">{t('practices.disclaimer', lang)}</div>
    <DailyChecklist lang={lang} client:visible />

    <p class="section-cta">
      <a href={`/ThePath/${lang}/paths/quickstart`}>{t('paths.quick_title', lang)} →</a>
    </p>
  </section>

  <!-- §4: Paths -->
  <section class="longread-section" id="paths">
    <div class="meta-label">§4 · {t('map.paths', lang).toUpperCase()}</div>
    <h2>{t('map.heading', lang)}</h2>
    <CardsGrid title="" items={[
      { icon: '▸', title: t('paths.quick_title', lang), description: t('paths.quick_desc', lang), href: `/ThePath/${lang}/paths/quickstart` },
      { icon: '▸', title: t('paths.mentor_title', lang), description: t('paths.mentor_desc', lang), href: `/ThePath/${lang}/paths/mentor` },
      { icon: '▸', title: t('paths.deep_title', lang), description: t('paths.deep_desc', lang), href: `/ThePath/${lang}/paths/deep` },
    ]} />
    <p class="section-cta">
      <a href={`/ThePath/${lang}/map`}>{t('map.view_all', lang)} →</a>
    </p>
  </section>

  <!-- §5: Explore Modules -->
  <section class="longread-section" id="explore">
    <div class="meta-label">{t('explore.section_label', lang)}</div>
    <h2>{t('explore.heading', lang)}</h2>
    <div class="module-grid">
      {modules.map((m) => (
        <a href={`/ThePath/${lang}/modules/${m.slug}`} class="module-card">
          <div class="module-card-icon">M{m.number}</div>
          <h3>{m.title[lang]}</h3>
          <p>{m.subtitle[lang]}</p>
        </a>
      ))}
    </div>
    <p class="section-cta">
      <a href={`/ThePath/${lang}/map`}>{t('explore.cta', lang)}</a>
    </p>
  </section>

</BaseLayout>

<style>
  .longread-section { max-width: var(--max-width-wide); margin: 0 auto; padding: 4rem 1.5rem; }
  .longread-section:nth-child(even) { background: var(--color-cosmic-light); }
  .longread-section h2 { text-align: center; margin-bottom: 2rem; }

  /* Shared Beliefs grid */
  .beliefs-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; }
  .belief-card {
    display: block; background: var(--color-card-bg); border: 1px solid var(--color-border);
    border-radius: 12px; padding: 1.5rem; text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }
  .belief-card:hover { border-color: var(--color-gold); transform: translateY(-2px); }
  .belief-card h3 { font-size: 1rem; margin: 0 0 0.5rem; font-weight: 500; color: var(--color-cosmic-text); }
  .belief-card p { font-size: 0.85rem; color: var(--color-cosmic-text-secondary); line-height: 1.5; margin: 0 0 0.75rem; }
  .belief-link { font-size: 0.82rem; color: var(--color-gold); font-weight: 500; }

  /* About section */
  .about-section { background: var(--color-cosmic-light); }
  .about-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(260px, 1fr)); gap: 1.5rem; max-width: 900px; margin: 0 auto; }
  .about-card { background: var(--color-card-bg); border: 1px solid var(--color-border); border-radius: 12px; padding: 1.75rem; text-align: center; }
  .about-card h3 { font-size: 1.15rem; margin: 0 0 0.75rem; font-weight: 500; color: var(--color-cosmic-text); }
  .about-card p { font-size: 0.9rem; color: var(--color-cosmic-text-secondary); line-height: 1.6; margin: 0; }

  /* Practice cards (reused from old design) */
  .practice-cards { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; }
  .practice-card { background: var(--color-card-bg); border: 1px solid var(--color-border); border-radius: 12px; padding: 1.5rem; text-align: center; }
  .practice-card p { font-size: 0.95rem; color: var(--color-cosmic-text); line-height: 1.6; margin: 0.5rem 0; }
  .practice-time { font-size: 0.8rem; color: var(--color-cosmic-text-secondary); display: block; margin-top: 0.5rem; }
  .practice-disclaimer { text-align: center; font-weight: 700; font-size: 0.75rem; margin: 1.5rem 0 1rem; color: var(--color-gold); letter-spacing: 0.05em; }

  /* Section CTA */
  .section-cta { text-align: center; margin-top: 1.5rem; }
  .section-cta a {
    color: var(--color-gold); font-weight: 500; text-decoration: none;
    font-size: 0.95rem; transition: color 0.15s;
  }
  .section-cta a:hover { color: var(--color-gold-hover); }

  /* Map all link */
  .map-all-link { text-align: center; margin-top: 1.5rem; }

  /* Module grid */
  .module-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 1rem; }
  .module-card {
    display: block; background: var(--color-card-bg); border: 1px solid var(--color-border);
    border-radius: 12px; padding: 1.25rem; text-decoration: none;
    transition: border-color 0.2s, transform 0.2s;
  }
  .module-card:hover { border-color: var(--color-gold); transform: translateY(-2px); }
  .module-card-icon {
    font-family: var(--font-mono); font-size: 0.85rem; font-weight: 700;
    color: var(--color-gold); margin-bottom: 0.5rem; letter-spacing: 0.05em;
  }
  .module-card h3 { font-size: 1rem; margin: 0.25rem 0; font-weight: 500; color: var(--color-cosmic-text); }
  .module-card p { font-size: 0.82rem; color: var(--color-cosmic-text-secondary); line-height: 1.5; margin: 0; }

  @media (max-width: 768px) {
    .longread-section { padding: 2.5rem 1rem; }
  }
</style>
