---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/home/Hero.astro';
import CardsGrid from '../../components/home/CardsGrid.astro';
import PathCards from '../../components/home/PathCards.astro';
import DailyChecklist from '../../components/interactive/DailyChecklist';
import EthicalCompass from '../../components/interactive/EthicalCompass';
import { t } from '../../i18n/ui';
import { getLangPaths } from '../../utils/static-paths';

export async function getStaticPaths() {
  return getLangPaths();
}

const { lang } = Astro.params;
const allPages = await getCollection('pages');
const page = allPages.find((e) => e.id.includes('index') && e.data?.lang === lang);
const { Content } = page ? await page.render() : { Content: null };
---

<BaseLayout lang={lang as 'ru' | 'en'} title={t('site.name', lang as 'ru' | 'en')}>
  <Hero lang={lang as 'ru' | 'en'} />
  <div class="home-content">
    <CardsGrid title={t('prohibitions.title', lang as 'ru' | 'en')} items={[
      { icon: '▸', title: t('prohibitions.1_title', lang as 'ru' | 'en'), description: t('prohibitions.1_desc', lang as 'ru' | 'en') },
      { icon: '▸', title: t('prohibitions.2_title', lang as 'ru' | 'en'), description: t('prohibitions.2_desc', lang as 'ru' | 'en') },
      { icon: '▸', title: t('prohibitions.3_title', lang as 'ru' | 'en'), description: t('prohibitions.3_desc', lang as 'ru' | 'en') },
    ]} />
    <CardsGrid title={t('principles.title', lang as 'ru' | 'en')} items={[
      { icon: '▸', title: t('principles.1_title', lang as 'ru' | 'en'), description: t('principles.1_desc', lang as 'ru' | 'en') },
      { icon: '▸', title: t('principles.2_title', lang as 'ru' | 'en'), description: t('principles.2_desc', lang as 'ru' | 'en') },
      { icon: '▸', title: t('principles.3_title', lang as 'ru' | 'en'), description: t('principles.3_desc', lang as 'ru' | 'en') },
      { icon: '▸', title: t('principles.4_title', lang as 'ru' | 'en'), description: t('principles.4_desc', lang as 'ru' | 'en') },
    ]} />
    {Content && <div class="home-prose"><Content /></div>}
    <div class="home-interactive">
      <DailyChecklist lang={lang as 'ru' | 'en'} client:visible />
      <EthicalCompass lang={lang as 'ru' | 'en'} client:visible />
    </div>
    <PathCards lang={lang as 'ru' | 'en'} />
  </div>
</BaseLayout>

<style>
  .home-content { max-width: 960px; margin: 0 auto; padding: 2rem 1.5rem 4rem; }
  .home-prose { max-width: 720px; margin: 3rem auto 0; }
  .home-prose :global(h2) { font-size: 1.75rem; margin-top: 2rem; }
  .home-prose :global(table) { width: 100%; }
  .home-interactive { display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 1.5rem; margin: 2rem 0; }
</style>
