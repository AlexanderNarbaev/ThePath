---
import { getCollection } from 'astro:content';
import ModuleLayout from '../../../layouts/ModuleLayout.astro';
import { modules } from '../../../i18n/modules';
import type { Lang } from '../../../i18n/ui';
import { BASE_PATH } from '../../../constants';

export async function getStaticPaths() {
  const allModules = await getCollection('modules');
  return allModules
    .filter((entry) => entry.data?.lang)
    .map((entry) => ({
      params: {
        lang: entry.data.lang,
        slug: entry.id.replace(/^modules\//, '').replace(/\.md$/, '').split('/').pop() || '',
      },
      props: { entryId: entry.id },
    }));
}

const { lang, slug } = Astro.params as { lang: Lang; slug: string };
const { entryId } = Astro.props as { entryId: string };

const allMods = await getCollection('modules');
const doc = allMods.find((entry) => entry.id === entryId);

if (!doc) return Astro.redirect(`${BASE_PATH}/${lang}`);

const { Content, headings } = await doc.render();

const meta = modules.find((m) => m.slug === slug);
const title = meta?.title[lang] ?? doc.data.title;
const subtitle = meta?.subtitle[lang] ?? doc.data.subtitle;
---

<ModuleLayout lang={lang} title={title} subtitle={subtitle} moduleNumber={doc.data.module_number} version={doc.data.version} headings={headings}>
  <Content />
</ModuleLayout>
