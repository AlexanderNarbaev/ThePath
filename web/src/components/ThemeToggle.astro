---
import { t, type Lang } from '../i18n/ui';
const { lang } = Astro.props as { lang: Lang };
---

<button
  id="theme-toggle-btn"
  class="theme-toggle"
  aria-label={t('theme.dark', lang)}
  title={t('theme.dark', lang)}
  onclick="(()=>{const h=document.documentElement,c=h.getAttribute('data-theme'),n=c==='dark'?'light':'dark';h.setAttribute('data-theme',n);localStorage.setItem('theme',n);const b=document.getElementById('theme-toggle-btn');if(b){b.setAttribute('aria-label',n==='dark'?'Dark theme':'Light theme');b.setAttribute('title',n==='dark'?'Dark theme':'Light theme')}})()"
  onkeydown="if (event.key === 'Enter' || event.key === ' ') { event.preventDefault(); this.click(); }"
>
  <svg class="icon icon-sun" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>
  <svg class="icon icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
  <span class="theme-label">{t('theme.light', lang)}</span>
</button>
<script>
  (() => {
    const btn = document.getElementById('theme-toggle-btn');
    if (!btn) return;
    const theme = document.documentElement.getAttribute('data-theme');
    const label = theme === 'dark' ? 'Dark theme' : 'Light theme';
    btn.setAttribute('aria-label', label);
    btn.setAttribute('title', label);
  })();
</script>

<style>
  .theme-toggle { background: var(--color-bg-secondary); border: 1px solid var(--color-border); border-radius: 8px; padding: 0.4rem 0.65rem; cursor: pointer; color: var(--color-text-secondary); display: flex; align-items: center; gap: 0.4rem; transition: all 0.2s; }
  .theme-toggle:hover { color: var(--color-gold); border-color: var(--color-gold); }
  .theme-label { font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.05em; white-space: nowrap; }
  :root .icon-sun { display: none; }
  :root .icon-moon { display: block; }
  [data-theme="light"] .icon-sun { display: block; }
  [data-theme="light"] .icon-moon { display: none; }
</style>
